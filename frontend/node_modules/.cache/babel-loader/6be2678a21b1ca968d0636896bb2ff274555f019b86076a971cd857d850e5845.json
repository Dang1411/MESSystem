{"ast":null,"code":"import \"core-js/modules/es.array.includes.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport scanApi from '../api/scan';\nimport defectApi from '../api/defects';\nexport default {\n  name: 'ScanProduction',\n  data() {\n    return {\n      scanCode: '',\n      lookingUp: false,\n      executing: false,\n      serialInfo: null,\n      defects: [],\n      lookupError: '',\n      execError: '',\n      execForm: {\n        result: '',\n        defectId: '',\n        notes: ''\n      },\n      execResult: null\n    };\n  },\n  computed: {\n    canExecute() {\n      if (!this.serialInfo) return false;\n      const terminal = ['SCRAP', 'FINISHED', 'CANCELLED'];\n      return !terminal.includes(this.serialInfo.status);\n    }\n  },\n  methods: {\n    async lookupSerial() {\n      if (!this.scanCode.trim()) return;\n      this.lookingUp = true;\n      this.lookupError = '';\n      this.serialInfo = null;\n      this.execResult = null;\n      this.execForm = {\n        result: '',\n        defectId: '',\n        notes: ''\n      };\n      try {\n        const res = await scanApi.getSerialInfo(this.scanCode.trim());\n        this.serialInfo = res.data;\n      } catch (e) {\n        this.lookupError = e.response?.data?.message || 'Không tìm thấy serial';\n      } finally {\n        this.lookingUp = false;\n      }\n    },\n    async executeStep() {\n      if (!this.execForm.result) return;\n      this.executing = true;\n      this.execError = '';\n      try {\n        const payload = {\n          serialCode: this.serialInfo.serialCode,\n          stepId: this.serialInfo.nextStepId || this.serialInfo.currentStepId,\n          result: this.execForm.result,\n          notes: this.execForm.notes || null,\n          defectId: this.execForm.defectId || null\n        };\n        const res = await scanApi.execute(payload);\n        this.execResult = res.data;\n        this.serialInfo = null;\n        this.scanCode = '';\n      } catch (e) {\n        this.execError = e.response?.data?.message || 'Lỗi khi thực hiện công đoạn';\n      } finally {\n        this.executing = false;\n      }\n    },\n    resetScan() {\n      this.scanCode = '';\n      this.serialInfo = null;\n      this.execResult = null;\n      this.lookupError = '';\n      this.execError = '';\n      this.execForm = {\n        result: '',\n        defectId: '',\n        notes: ''\n      };\n      this.$nextTick(() => {\n        if (this.$refs.scanInput) this.$refs.scanInput.focus();\n      });\n    },\n    statusColor(status) {\n      const map = {\n        WAITING: '#6c757d',\n        IN_PROGRESS: '#1565C0',\n        OK: '#2E7D32',\n        NG: '#C62828',\n        REWORK: '#fd7e14',\n        SCRAP: '#6f42c1',\n        HOLD: '#F9A825',\n        FINISHED: '#0288D1'\n      };\n      return map[status] || '#6c757d';\n    },\n    async loadDefects() {\n      const res = await defectApi.getAll();\n      this.defects = res.data.filter(d => d.isActive);\n    }\n  },\n  mounted() {\n    this.loadDefects();\n    this.$nextTick(() => {\n      if (this.$refs.scanInput) this.$refs.scanInput.focus();\n    });\n  }\n};","map":{"version":3,"names":["scanApi","defectApi","name","data","scanCode","lookingUp","executing","serialInfo","defects","lookupError","execError","execForm","result","defectId","notes","execResult","computed","canExecute","terminal","includes","status","methods","lookupSerial","trim","res","getSerialInfo","e","response","message","executeStep","payload","serialCode","stepId","nextStepId","currentStepId","execute","resetScan","$nextTick","$refs","scanInput","focus","statusColor","map","WAITING","IN_PROGRESS","OK","NG","REWORK","SCRAP","HOLD","FINISHED","loadDefects","getAll","filter","d","isActive","mounted"],"sources":["src/views/ScanProduction.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"row justify-content-center\">\r\n      <div class=\"col-md-8\">\r\n\r\n        <!-- Scan Input -->\r\n        <div class=\"card card-mes mb-4 scan-card\">\r\n          <div class=\"card-header text-white\" style=\"background: #1565C0;\">\r\n            <h5 class=\"mb-0\">📡 Quét Serial / Nhập mã</h5>\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <div class=\"input-group input-group-lg\">\r\n              <input\r\n                ref=\"scanInput\"\r\n                v-model=\"scanCode\"\r\n                @keyup.enter=\"lookupSerial\"\r\n                type=\"text\"\r\n                class=\"form-control form-control-lg\"\r\n                placeholder=\"Quét QR hoặc nhập mã serial...\"\r\n                autofocus\r\n              />\r\n              <div class=\"input-group-append\">\r\n                <button class=\"btn btn-primary btn-lg\" @click=\"lookupSerial\" :disabled=\"lookingUp\">\r\n                  {{ lookingUp ? '⏳' : '🔍 Tra cứu' }}\r\n                </button>\r\n              </div>\r\n            </div>\r\n            <div class=\"text-muted small mt-2\">\r\n              💡 Nhấn Enter hoặc nhấn nút Tra cứu sau khi quét/nhập mã serial\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Error -->\r\n        <div class=\"alert alert-danger\" v-if=\"lookupError\">\r\n          ❌ {{ lookupError }}\r\n          <button class=\"close\" @click=\"lookupError = ''\"><span>&times;</span></button>\r\n        </div>\r\n\r\n        <!-- Serial Info -->\r\n        <div v-if=\"serialInfo\" class=\"card card-mes mb-4\">\r\n          <div class=\"card-header d-flex align-items-center justify-content-between\"\r\n               :style=\"{ background: statusColor(serialInfo.status), color: '#fff' }\">\r\n            <div>\r\n              <h5 class=\"mb-0\">{{ serialInfo.serialCode }}</h5>\r\n              <small>{{ serialInfo.productName }}</small>\r\n            </div>\r\n            <span class=\"badge badge-light\" style=\"font-size:1rem; padding:8px 16px\">\r\n              {{ serialInfo.status }}\r\n            </span>\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <div class=\"row\">\r\n              <div class=\"col-md-6\">\r\n                <p class=\"mb-1\"><strong>Lệnh sản xuất:</strong> {{ serialInfo.orderCode }}</p>\r\n                <p class=\"mb-1\"><strong>Sản phẩm:</strong> {{ serialInfo.productName }} ({{ serialInfo.productCode }})</p>\r\n              </div>\r\n              <div class=\"col-md-6\">\r\n                <p class=\"mb-1\"><strong>Công đoạn hiện tại:</strong>\r\n                  <span v-if=\"serialInfo.currentStepName\" class=\"badge badge-info\">{{ serialInfo.currentStepName }}</span>\r\n                  <span v-else class=\"text-muted\">—</span>\r\n                </p>\r\n                <p class=\"mb-1\"><strong>Công đoạn tiếp theo:</strong>\r\n                  <span v-if=\"serialInfo.nextStepName\" class=\"badge badge-warning\">{{ serialInfo.nextStepName }}</span>\r\n                  <span v-else class=\"text-muted\">—</span>\r\n                </p>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Process route progress -->\r\n            <div class=\"mt-3\" v-if=\"serialInfo.historyItems && serialInfo.historyItems.length\">\r\n              <strong class=\"small\">Tiến trình công đoạn đã thực hiện:</strong>\r\n              <div class=\"route-progress mt-2\">\r\n                <div v-for=\"(h, i) in serialInfo.historyItems\" :key=\"i\"\r\n                     class=\"route-step\" :class=\"'result-' + h.result.toLowerCase()\">\r\n                  <div class=\"step-num\">{{ i + 1 }}</div>\r\n                  <div class=\"step-info\">\r\n                    <div class=\"step-name\">{{ h.stepName }}</div>\r\n                    <div class=\"step-result\">{{ h.result }}</div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <!-- Execution panel - only if not terminal status -->\r\n          <div class=\"card-footer bg-light\" v-if=\"canExecute\">\r\n            <h6 class=\"mb-3\">⚡ Thực hiện công đoạn: <strong>{{ serialInfo.nextStepName || serialInfo.currentStepName }}</strong></h6>\r\n            <div class=\"alert alert-danger\" v-if=\"execError\">{{ execError }}</div>\r\n\r\n            <div class=\"form-row\">\r\n              <div class=\"form-group col-md-4\">\r\n                <label class=\"small font-weight-bold\">Kết quả <span class=\"text-danger\">*</span></label>\r\n                <select v-model=\"execForm.result\" class=\"form-control\">\r\n                  <option value=\"\">-- Chọn kết quả --</option>\r\n                  <option value=\"OK\">✅ OK - Đạt</option>\r\n                  <option value=\"NG\">❌ NG - Không đạt</option>\r\n                  <option value=\"REWORK\">🔄 REWORK - Làm lại</option>\r\n                  <option value=\"SCRAP\">🗑 SCRAP - Phế phẩm</option>\r\n                  <option value=\"HOLD\">⏸ HOLD - Giữ lại</option>\r\n                </select>\r\n              </div>\r\n              <div class=\"form-group col-md-4\" v-if=\"execForm.result === 'NG' || execForm.result === 'SCRAP'\">\r\n                <label class=\"small font-weight-bold\">Loại lỗi</label>\r\n                <select v-model=\"execForm.defectId\" class=\"form-control\">\r\n                  <option value=\"\">-- Chọn lỗi --</option>\r\n                  <option v-for=\"d in defects\" :key=\"d.id\" :value=\"d.id\">{{ d.defectName }}</option>\r\n                </select>\r\n              </div>\r\n              <div class=\"form-group col-md-4\">\r\n                <label class=\"small font-weight-bold\">Ghi chú</label>\r\n                <input v-model=\"execForm.notes\" type=\"text\" class=\"form-control\" placeholder=\"Ghi chú thêm...\">\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"d-flex gap-2 mt-2\">\r\n              <button class=\"btn btn-success\" @click=\"executeStep\" :disabled=\"!execForm.result || executing\">\r\n                {{ executing ? '⏳ Đang xử lý...' : '✅ Xác nhận thực hiện' }}\r\n              </button>\r\n              <button class=\"btn btn-outline-secondary ml-2\" @click=\"resetScan\">🔄 Quét serial khác</button>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"card-footer text-muted\" v-else>\r\n            <em>Serial ở trạng thái {{ serialInfo.status }} — không thể thực hiện thêm.</em>\r\n            <button class=\"btn btn-sm btn-outline-primary ml-3\" @click=\"resetScan\">Quét serial khác</button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Success result -->\r\n        <div class=\"alert alert-success alert-result\" v-if=\"execResult\">\r\n          <h5>{{ execResult.message }}</h5>\r\n          <p class=\"mb-0\">Serial mới: <strong>{{ execResult.serialCode }}</strong> — Trạng thái: <strong>{{ execResult.status }}</strong></p>\r\n          <button class=\"btn btn-success mt-2\" @click=\"resetScan\">📡 Quét serial tiếp theo</button>\r\n        </div>\r\n\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport scanApi from '../api/scan'\r\nimport defectApi from '../api/defects'\r\n\r\nexport default {\r\n  name: 'ScanProduction',\r\n  data() {\r\n    return {\r\n      scanCode: '',\r\n      lookingUp: false, executing: false,\r\n      serialInfo: null,\r\n      defects: [],\r\n      lookupError: '', execError: '',\r\n      execForm: { result: '', defectId: '', notes: '' },\r\n      execResult: null\r\n    }\r\n  },\r\n  computed: {\r\n    canExecute() {\r\n      if (!this.serialInfo) return false\r\n      const terminal = ['SCRAP', 'FINISHED', 'CANCELLED']\r\n      return !terminal.includes(this.serialInfo.status)\r\n    }\r\n  },\r\n  methods: {\r\n    async lookupSerial() {\r\n      if (!this.scanCode.trim()) return\r\n      this.lookingUp = true\r\n      this.lookupError = ''\r\n      this.serialInfo = null\r\n      this.execResult = null\r\n      this.execForm = { result: '', defectId: '', notes: '' }\r\n      try {\r\n        const res = await scanApi.getSerialInfo(this.scanCode.trim())\r\n        this.serialInfo = res.data\r\n      } catch (e) {\r\n        this.lookupError = e.response?.data?.message || 'Không tìm thấy serial'\r\n      } finally { this.lookingUp = false }\r\n    },\r\n    async executeStep() {\r\n      if (!this.execForm.result) return\r\n      this.executing = true; this.execError = ''\r\n      try {\r\n        const payload = {\r\n          serialCode: this.serialInfo.serialCode,\r\n          stepId: this.serialInfo.nextStepId || this.serialInfo.currentStepId,\r\n          result: this.execForm.result,\r\n          notes: this.execForm.notes || null,\r\n          defectId: this.execForm.defectId || null\r\n        }\r\n        const res = await scanApi.execute(payload)\r\n        this.execResult = res.data\r\n        this.serialInfo = null\r\n        this.scanCode = ''\r\n      } catch (e) {\r\n        this.execError = e.response?.data?.message || 'Lỗi khi thực hiện công đoạn'\r\n      } finally { this.executing = false }\r\n    },\r\n    resetScan() {\r\n      this.scanCode = ''\r\n      this.serialInfo = null\r\n      this.execResult = null\r\n      this.lookupError = ''\r\n      this.execError = ''\r\n      this.execForm = { result: '', defectId: '', notes: '' }\r\n      this.$nextTick(() => { if (this.$refs.scanInput) this.$refs.scanInput.focus() })\r\n    },\r\n    statusColor(status) {\r\n      const map = {\r\n        WAITING: '#6c757d', IN_PROGRESS: '#1565C0', OK: '#2E7D32',\r\n        NG: '#C62828', REWORK: '#fd7e14', SCRAP: '#6f42c1',\r\n        HOLD: '#F9A825', FINISHED: '#0288D1'\r\n      }\r\n      return map[status] || '#6c757d'\r\n    },\r\n    async loadDefects() {\r\n      const res = await defectApi.getAll()\r\n      this.defects = res.data.filter(d => d.isActive)\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadDefects()\r\n    this.$nextTick(() => { if (this.$refs.scanInput) this.$refs.scanInput.focus() })\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.scan-card { border-top: 4px solid #1565C0; }\r\n\r\n.route-progress { display: flex; flex-wrap: wrap; gap: 8px; }\r\n.route-step {\r\n  display: flex; align-items: center; gap: 8px;\r\n  padding: 6px 12px; border-radius: 8px;\r\n  border: 2px solid #ddd; background: #f8f9fa;\r\n  font-size: 0.82rem;\r\n}\r\n.result-ok     { border-color: #2E7D32; background: #e8f5e9; }\r\n.result-ng     { border-color: #C62828; background: #ffebee; }\r\n.result-rework { border-color: #fd7e14; background: #fff3e0; }\r\n.result-scrap  { border-color: #6f42c1; background: #f3e5f5; }\r\n.result-hold   { border-color: #F9A825; background: #fffde7; }\r\n\r\n.step-num {\r\n  width: 24px; height: 24px;\r\n  background: #1565C0; color: #fff;\r\n  border-radius: 50%;\r\n  display: flex; align-items: center; justify-content: center;\r\n  font-weight: 700; font-size: 0.75rem;\r\n  flex-shrink: 0;\r\n}\r\n.step-name { font-weight: 600; }\r\n.step-result { font-size: 0.7rem; color: #666; text-transform: uppercase; }\r\n\r\n.alert-result {\r\n  border-radius: 10px; border: none;\r\n  padding: 20px 24px;\r\n  box-shadow: 0 4px 16px rgba(0,128,0,0.15);\r\n}\r\n</style>\r\n"],"mappings":";;;AA8IA,OAAAA,OAAA;AACA,OAAAC,SAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,SAAA;MAAAC,SAAA;MACAC,UAAA;MACAC,OAAA;MACAC,WAAA;MAAAC,SAAA;MACAC,QAAA;QAAAC,MAAA;QAAAC,QAAA;QAAAC,KAAA;MAAA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACAC,WAAA;MACA,UAAAV,UAAA;MACA,MAAAW,QAAA;MACA,QAAAA,QAAA,CAAAC,QAAA,MAAAZ,UAAA,CAAAa,MAAA;IACA;EACA;EACAC,OAAA;IACA,MAAAC,aAAA;MACA,UAAAlB,QAAA,CAAAmB,IAAA;MACA,KAAAlB,SAAA;MACA,KAAAI,WAAA;MACA,KAAAF,UAAA;MACA,KAAAQ,UAAA;MACA,KAAAJ,QAAA;QAAAC,MAAA;QAAAC,QAAA;QAAAC,KAAA;MAAA;MACA;QACA,MAAAU,GAAA,SAAAxB,OAAA,CAAAyB,aAAA,MAAArB,QAAA,CAAAmB,IAAA;QACA,KAAAhB,UAAA,GAAAiB,GAAA,CAAArB,IAAA;MACA,SAAAuB,CAAA;QACA,KAAAjB,WAAA,GAAAiB,CAAA,CAAAC,QAAA,EAAAxB,IAAA,EAAAyB,OAAA;MACA;QAAA,KAAAvB,SAAA;MAAA;IACA;IACA,MAAAwB,YAAA;MACA,UAAAlB,QAAA,CAAAC,MAAA;MACA,KAAAN,SAAA;MAAA,KAAAI,SAAA;MACA;QACA,MAAAoB,OAAA;UACAC,UAAA,OAAAxB,UAAA,CAAAwB,UAAA;UACAC,MAAA,OAAAzB,UAAA,CAAA0B,UAAA,SAAA1B,UAAA,CAAA2B,aAAA;UACAtB,MAAA,OAAAD,QAAA,CAAAC,MAAA;UACAE,KAAA,OAAAH,QAAA,CAAAG,KAAA;UACAD,QAAA,OAAAF,QAAA,CAAAE,QAAA;QACA;QACA,MAAAW,GAAA,SAAAxB,OAAA,CAAAmC,OAAA,CAAAL,OAAA;QACA,KAAAf,UAAA,GAAAS,GAAA,CAAArB,IAAA;QACA,KAAAI,UAAA;QACA,KAAAH,QAAA;MACA,SAAAsB,CAAA;QACA,KAAAhB,SAAA,GAAAgB,CAAA,CAAAC,QAAA,EAAAxB,IAAA,EAAAyB,OAAA;MACA;QAAA,KAAAtB,SAAA;MAAA;IACA;IACA8B,UAAA;MACA,KAAAhC,QAAA;MACA,KAAAG,UAAA;MACA,KAAAQ,UAAA;MACA,KAAAN,WAAA;MACA,KAAAC,SAAA;MACA,KAAAC,QAAA;QAAAC,MAAA;QAAAC,QAAA;QAAAC,KAAA;MAAA;MACA,KAAAuB,SAAA;QAAA,SAAAC,KAAA,CAAAC,SAAA,OAAAD,KAAA,CAAAC,SAAA,CAAAC,KAAA;MAAA;IACA;IACAC,YAAArB,MAAA;MACA,MAAAsB,GAAA;QACAC,OAAA;QAAAC,WAAA;QAAAC,EAAA;QACAC,EAAA;QAAAC,MAAA;QAAAC,KAAA;QACAC,IAAA;QAAAC,QAAA;MACA;MACA,OAAAR,GAAA,CAAAtB,MAAA;IACA;IACA,MAAA+B,YAAA;MACA,MAAA3B,GAAA,SAAAvB,SAAA,CAAAmD,MAAA;MACA,KAAA5C,OAAA,GAAAgB,GAAA,CAAArB,IAAA,CAAAkD,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAL,WAAA;IACA,KAAAd,SAAA;MAAA,SAAAC,KAAA,CAAAC,SAAA,OAAAD,KAAA,CAAAC,SAAA,CAAAC,KAAA;IAAA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}