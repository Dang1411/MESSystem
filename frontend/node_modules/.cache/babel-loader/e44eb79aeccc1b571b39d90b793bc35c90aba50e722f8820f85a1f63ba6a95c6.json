{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport Chart from 'chart.js';\nimport dashboardApi from '../api/dashboard';\nexport default {\n  name: 'Dashboard',\n  data() {\n    return {\n      stats: null,\n      loading: true,\n      prodChart: null,\n      qualChart: null\n    };\n  },\n  computed: {\n    statCards() {\n      if (!this.stats) return [];\n      return [{\n        label: 'Lệnh đang thực hiện',\n        value: this.stats.ordersInProgress || 0,\n        icon: '🏭',\n        color: '#1565C0'\n      }, {\n        label: 'Serial đã hoàn thành',\n        value: this.stats.totalFinished || 0,\n        icon: '✅',\n        color: '#2E7D32'\n      }, {\n        label: 'Serial bị lỗi NG',\n        value: this.stats.totalNg || 0,\n        icon: '❌',\n        color: '#C62828'\n      }, {\n        label: 'Serial đang giữ HOLD',\n        value: this.stats.totalHold || 0,\n        icon: '⏸',\n        color: '#F9A825'\n      }];\n    },\n    orderStats() {\n      if (!this.stats) return [];\n      return [{\n        label: 'Mới tạo',\n        value: this.stats.ordersCreated || 0,\n        color: '#6c757d'\n      }, {\n        label: 'Đang thực hiện',\n        value: this.stats.ordersInProgress || 0,\n        color: '#1565C0'\n      }, {\n        label: 'Hoàn thành',\n        value: this.stats.ordersCompleted || 0,\n        color: '#2E7D32'\n      }, {\n        label: 'Đã hủy',\n        value: this.stats.ordersCancelled || 0,\n        color: '#C62828'\n      }];\n    },\n    completionRate() {\n      if (!this.stats) return 0;\n      return this.stats.completionRate ? parseFloat(this.stats.completionRate).toFixed(1) : 0;\n    },\n    ngRate() {\n      if (!this.stats) return 0;\n      return this.stats.ngRate ? parseFloat(this.stats.ngRate).toFixed(1) : 0;\n    },\n    qualityLegend() {\n      if (!this.stats || !this.stats.qualityChart) return [];\n      const labelMap = {\n        FINISHED: 'Hoàn thành',\n        NG: 'Lỗi NG',\n        REWORK: 'Làm lại',\n        SCRAP: 'Loại bỏ',\n        HOLD: 'Tạm giữ',\n        WAITING: 'Chờ xử lý',\n        IN_PROGRESS: 'Đang làm'\n      };\n      const colors = ['#2E7D32', '#C62828', '#fd7e14', '#6f42c1', '#F9A825', '#0dcaf0', '#1565C0'];\n      return Object.entries(this.stats.qualityChart).map(([key, val], i) => ({\n        label: labelMap[key] || key,\n        value: val,\n        color: colors[i % colors.length]\n      }));\n    }\n  },\n  methods: {\n    async loadStats() {\n      this.loading = true;\n      try {\n        const res = await dashboardApi.getStats();\n        this.stats = res.data;\n        this.$nextTick(() => {\n          this.renderProductionChart();\n          this.renderQualityChart();\n        });\n      } catch (e) {\n        console.error('Lỗi tải dashboard:', e);\n      } finally {\n        this.loading = false;\n      }\n    },\n    renderProductionChart() {\n      if (this.prodChart) {\n        this.prodChart.destroy();\n      }\n      const ctx = this.$refs.productionChart;\n      if (!ctx || !this.stats || !this.stats.productionChart) return;\n      const data = this.stats.productionChart;\n      this.prodChart = new Chart(ctx, {\n        type: 'bar',\n        data: {\n          labels: data.map(d => d.date),\n          datasets: [{\n            label: 'Serial hoàn thành',\n            data: data.map(d => d.count),\n            backgroundColor: 'rgba(21, 101, 192, 0.7)',\n            borderColor: '#1565C0',\n            borderWidth: 1,\n            borderRadius: 4\n          }]\n        },\n        options: {\n          responsive: true,\n          maintainAspectRatio: true,\n          scales: {\n            yAxes: [{\n              ticks: {\n                beginAtZero: true,\n                stepSize: 1\n              }\n            }]\n          },\n          legend: {\n            display: false\n          }\n        }\n      });\n    },\n    renderQualityChart() {\n      if (this.qualChart) {\n        this.qualChart.destroy();\n      }\n      const ctx = this.$refs.qualityChart;\n      if (!ctx || !this.stats || !this.stats.qualityChart) return;\n      const labelMap = {\n        FINISHED: 'Hoàn thành',\n        NG: 'Lỗi NG',\n        REWORK: 'Làm lại',\n        SCRAP: 'Loại bỏ',\n        HOLD: 'Tạm giữ',\n        WAITING: 'Chờ xử lý',\n        IN_PROGRESS: 'Đang làm'\n      };\n      const colors = ['#2E7D32', '#C62828', '#fd7e14', '#6f42c1', '#F9A825', '#0dcaf0', '#1565C0'];\n      const entries = Object.entries(this.stats.qualityChart);\n      this.qualChart = new Chart(ctx, {\n        type: 'doughnut',\n        data: {\n          labels: entries.map(([k]) => labelMap[k] || k),\n          datasets: [{\n            data: entries.map(([, v]) => v),\n            backgroundColor: colors.slice(0, entries.length)\n          }]\n        },\n        options: {\n          responsive: false,\n          legend: {\n            display: false\n          },\n          cutoutPercentage: 65\n        }\n      });\n    }\n  },\n  mounted() {\n    this.loadStats();\n  }\n};","map":{"version":3,"names":["Chart","dashboardApi","name","data","stats","loading","prodChart","qualChart","computed","statCards","label","value","ordersInProgress","icon","color","totalFinished","totalNg","totalHold","orderStats","ordersCreated","ordersCompleted","ordersCancelled","completionRate","parseFloat","toFixed","ngRate","qualityLegend","qualityChart","labelMap","FINISHED","NG","REWORK","SCRAP","HOLD","WAITING","IN_PROGRESS","colors","Object","entries","map","key","val","i","length","methods","loadStats","res","getStats","$nextTick","renderProductionChart","renderQualityChart","e","console","error","destroy","ctx","$refs","productionChart","type","labels","d","date","datasets","count","backgroundColor","borderColor","borderWidth","borderRadius","options","responsive","maintainAspectRatio","scales","yAxes","ticks","beginAtZero","stepSize","legend","display","k","v","slice","cutoutPercentage","mounted"],"sources":["src/views/Dashboard.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- Stat Cards -->\r\n    <div class=\"row mb-4\">\r\n      <div class=\"col-md-3 mb-3\" v-for=\"card in statCards\" :key=\"card.label\">\r\n        <div class=\"card card-mes stat-card\" :style=\"{ borderTop: '4px solid ' + card.color }\">\r\n          <div class=\"card-body d-flex align-items-center\">\r\n            <div class=\"stat-icon\" :style=\"{ background: card.color + '22', color: card.color }\">\r\n              {{ card.icon }}\r\n            </div>\r\n            <div class=\"ml-3\">\r\n              <div class=\"stat-value\">{{ card.value }}</div>\r\n              <div class=\"stat-label\">{{ card.label }}</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Charts row -->\r\n    <div class=\"row mb-4\">\r\n      <div class=\"col-md-8 mb-3\">\r\n        <div class=\"card card-mes\">\r\n          <div class=\"card-header bg-white\">\r\n            <strong>📈 Sản lượng 7 ngày gần nhất</strong>\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <canvas ref=\"productionChart\" height=\"100\"></canvas>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"col-md-4 mb-3\">\r\n        <div class=\"card card-mes\">\r\n          <div class=\"card-header bg-white\">\r\n            <strong>🍩 Tỷ lệ chất lượng Serial</strong>\r\n          </div>\r\n          <div class=\"card-body d-flex flex-column align-items-center\">\r\n            <canvas ref=\"qualityChart\" width=\"200\" height=\"200\"></canvas>\r\n            <div class=\"quality-legend mt-3\" v-if=\"stats\">\r\n              <div v-for=\"(item, i) in qualityLegend\" :key=\"i\" class=\"legend-item\">\r\n                <span class=\"legend-dot\" :style=\"{ background: item.color }\"></span>\r\n                {{ item.label }}: {{ item.value }}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Defect steps + Order summary -->\r\n    <div class=\"row\">\r\n      <div class=\"col-md-6 mb-3\">\r\n        <div class=\"card card-mes\">\r\n          <div class=\"card-header bg-white\">\r\n            <strong>⚠ Top 5 Công đoạn có Lỗi nhiều nhất</strong>\r\n          </div>\r\n          <div class=\"card-body p-0\">\r\n            <table class=\"table table-sm mb-0\" v-if=\"stats && stats.topDefectSteps && stats.topDefectSteps.length\">\r\n              <thead class=\"thead-light\">\r\n                <tr><th>Công đoạn</th><th class=\"text-right\">Số lỗi NG</th></tr>\r\n              </thead>\r\n              <tbody>\r\n                <tr v-for=\"(step, i) in stats.topDefectSteps\" :key=\"i\">\r\n                  <td>{{ step.stepName }}</td>\r\n                  <td class=\"text-right\">\r\n                    <span class=\"badge badge-danger\">{{ step.ngCount }}</span>\r\n                  </td>\r\n                </tr>\r\n              </tbody>\r\n            </table>\r\n            <div class=\"p-3 text-muted text-center\" v-else>Chưa có dữ liệu</div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"col-md-6 mb-3\">\r\n        <div class=\"card card-mes\">\r\n          <div class=\"card-header bg-white\">\r\n            <strong>📋 Tình trạng Lệnh sản xuất</strong>\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <div class=\"order-stat-row\" v-if=\"stats\">\r\n              <div class=\"order-stat-item\" v-for=\"item in orderStats\" :key=\"item.label\">\r\n                <div class=\"order-stat-num\" :style=\"{ color: item.color }\">{{ item.value }}</div>\r\n                <div class=\"order-stat-label\">{{ item.label }}</div>\r\n              </div>\r\n            </div>\r\n            <div class=\"mt-3\" v-if=\"stats\">\r\n              <div class=\"d-flex justify-content-between small mb-1\">\r\n                <span>Tỷ lệ hoàn thành tổng thể</span>\r\n                <strong>{{ completionRate }}%</strong>\r\n              </div>\r\n              <div class=\"progress\" style=\"height: 10px;\">\r\n                <div class=\"progress-bar bg-success\" :style=\"{ width: completionRate + '%' }\"></div>\r\n              </div>\r\n              <div class=\"d-flex justify-content-between small mt-2 mb-1\">\r\n                <span>Tỷ lệ lỗi NG</span>\r\n                <strong class=\"text-danger\">{{ ngRate }}%</strong>\r\n              </div>\r\n              <div class=\"progress\" style=\"height: 10px;\">\r\n                <div class=\"progress-bar bg-danger\" :style=\"{ width: ngRate + '%' }\"></div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Loading overlay -->\r\n    <div class=\"loading-overlay\" v-if=\"loading\">\r\n      <div class=\"spinner-border text-primary\" role=\"status\"></div>\r\n      <p>Đang tải dữ liệu...</p>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Chart from 'chart.js'\r\nimport dashboardApi from '../api/dashboard'\r\n\r\nexport default {\r\n  name: 'Dashboard',\r\n  data() {\r\n    return {\r\n      stats: null,\r\n      loading: true,\r\n      prodChart: null,\r\n      qualChart: null\r\n    }\r\n  },\r\n  computed: {\r\n    statCards() {\r\n      if (!this.stats) return []\r\n      return [\r\n        { label: 'Lệnh đang thực hiện', value: this.stats.ordersInProgress || 0, icon: '🏭', color: '#1565C0' },\r\n        { label: 'Serial đã hoàn thành', value: this.stats.totalFinished || 0,   icon: '✅', color: '#2E7D32' },\r\n        { label: 'Serial bị lỗi NG',     value: this.stats.totalNg || 0,         icon: '❌', color: '#C62828' },\r\n        { label: 'Serial đang giữ HOLD', value: this.stats.totalHold || 0,       icon: '⏸', color: '#F9A825' }\r\n      ]\r\n    },\r\n    orderStats() {\r\n      if (!this.stats) return []\r\n      return [\r\n        { label: 'Mới tạo',        value: this.stats.ordersCreated || 0,    color: '#6c757d' },\r\n        { label: 'Đang thực hiện', value: this.stats.ordersInProgress || 0, color: '#1565C0' },\r\n        { label: 'Hoàn thành',     value: this.stats.ordersCompleted || 0,  color: '#2E7D32' },\r\n        { label: 'Đã hủy',         value: this.stats.ordersCancelled || 0,  color: '#C62828' }\r\n      ]\r\n    },\r\n    completionRate() {\r\n      if (!this.stats) return 0\r\n      return this.stats.completionRate ? parseFloat(this.stats.completionRate).toFixed(1) : 0\r\n    },\r\n    ngRate() {\r\n      if (!this.stats) return 0\r\n      return this.stats.ngRate ? parseFloat(this.stats.ngRate).toFixed(1) : 0\r\n    },\r\n    qualityLegend() {\r\n      if (!this.stats || !this.stats.qualityChart) return []\r\n      const labelMap = { FINISHED: 'Hoàn thành', NG: 'Lỗi NG', REWORK: 'Làm lại', SCRAP: 'Loại bỏ', HOLD: 'Tạm giữ', WAITING: 'Chờ xử lý', IN_PROGRESS: 'Đang làm' }\r\n      const colors = ['#2E7D32','#C62828','#fd7e14','#6f42c1','#F9A825','#0dcaf0','#1565C0']\r\n      return Object.entries(this.stats.qualityChart).map(([key, val], i) => ({\r\n        label: labelMap[key] || key,\r\n        value: val,\r\n        color: colors[i % colors.length]\r\n      }))\r\n    }\r\n  },\r\n  methods: {\r\n    async loadStats() {\r\n      this.loading = true\r\n      try {\r\n        const res = await dashboardApi.getStats()\r\n        this.stats = res.data\r\n        this.$nextTick(() => {\r\n          this.renderProductionChart()\r\n          this.renderQualityChart()\r\n        })\r\n      } catch (e) {\r\n        console.error('Lỗi tải dashboard:', e)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    renderProductionChart() {\r\n      if (this.prodChart) { this.prodChart.destroy() }\r\n      const ctx = this.$refs.productionChart\r\n      if (!ctx || !this.stats || !this.stats.productionChart) return\r\n      const data = this.stats.productionChart\r\n      this.prodChart = new Chart(ctx, {\r\n        type: 'bar',\r\n        data: {\r\n          labels: data.map(d => d.date),\r\n          datasets: [{\r\n            label: 'Serial hoàn thành',\r\n            data: data.map(d => d.count),\r\n            backgroundColor: 'rgba(21, 101, 192, 0.7)',\r\n            borderColor: '#1565C0',\r\n            borderWidth: 1,\r\n            borderRadius: 4\r\n          }]\r\n        },\r\n        options: {\r\n          responsive: true,\r\n          maintainAspectRatio: true,\r\n          scales: {\r\n            yAxes: [{ ticks: { beginAtZero: true, stepSize: 1 } }]\r\n          },\r\n          legend: { display: false }\r\n        }\r\n      })\r\n    },\r\n    renderQualityChart() {\r\n      if (this.qualChart) { this.qualChart.destroy() }\r\n      const ctx = this.$refs.qualityChart\r\n      if (!ctx || !this.stats || !this.stats.qualityChart) return\r\n      const labelMap = { FINISHED: 'Hoàn thành', NG: 'Lỗi NG', REWORK: 'Làm lại', SCRAP: 'Loại bỏ', HOLD: 'Tạm giữ', WAITING: 'Chờ xử lý', IN_PROGRESS: 'Đang làm' }\r\n      const colors = ['#2E7D32','#C62828','#fd7e14','#6f42c1','#F9A825','#0dcaf0','#1565C0']\r\n      const entries = Object.entries(this.stats.qualityChart)\r\n      this.qualChart = new Chart(ctx, {\r\n        type: 'doughnut',\r\n        data: {\r\n          labels: entries.map(([k]) => labelMap[k] || k),\r\n          datasets: [{\r\n            data: entries.map(([, v]) => v),\r\n            backgroundColor: colors.slice(0, entries.length)\r\n          }]\r\n        },\r\n        options: {\r\n          responsive: false,\r\n          legend: { display: false },\r\n          cutoutPercentage: 65\r\n        }\r\n      })\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadStats()\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.stat-card { cursor: default; }\r\n.stat-icon {\r\n  width: 48px; height: 48px;\r\n  border-radius: 12px;\r\n  display: flex; align-items: center; justify-content: center;\r\n  font-size: 1.5rem;\r\n  flex-shrink: 0;\r\n}\r\n.stat-value { font-size: 1.6rem; font-weight: 700; color: #1a3a5c; }\r\n.stat-label { font-size: 0.78rem; color: #666; }\r\n\r\n.quality-legend { width: 100%; }\r\n.legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; margin-bottom: 4px; }\r\n.legend-dot { width: 12px; height: 12px; border-radius: 2px; flex-shrink: 0; }\r\n\r\n.order-stat-row { display: flex; justify-content: space-around; text-align: center; }\r\n.order-stat-num { font-size: 1.8rem; font-weight: 700; }\r\n.order-stat-label { font-size: 0.72rem; color: #666; }\r\n\r\n.loading-overlay {\r\n  position: fixed; top: 0; left: 0; right: 0; bottom: 0;\r\n  background: rgba(255,255,255,0.7);\r\n  display: flex; flex-direction: column;\r\n  align-items: center; justify-content: center;\r\n  z-index: 999;\r\n}\r\n</style>\r\n"],"mappings":";;AAqHA,OAAAA,KAAA;AACA,OAAAC,YAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,KAAA;MACAC,OAAA;MACAC,SAAA;MACAC,SAAA;IACA;EACA;EACAC,QAAA;IACAC,UAAA;MACA,UAAAL,KAAA;MACA,QACA;QAAAM,KAAA;QAAAC,KAAA,OAAAP,KAAA,CAAAQ,gBAAA;QAAAC,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAJ,KAAA;QAAAC,KAAA,OAAAP,KAAA,CAAAW,aAAA;QAAAF,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAJ,KAAA;QAAAC,KAAA,OAAAP,KAAA,CAAAY,OAAA;QAAAH,IAAA;QAAAC,KAAA;MAAA,GACA;QAAAJ,KAAA;QAAAC,KAAA,OAAAP,KAAA,CAAAa,SAAA;QAAAJ,IAAA;QAAAC,KAAA;MAAA,EACA;IACA;IACAI,WAAA;MACA,UAAAd,KAAA;MACA,QACA;QAAAM,KAAA;QAAAC,KAAA,OAAAP,KAAA,CAAAe,aAAA;QAAAL,KAAA;MAAA,GACA;QAAAJ,KAAA;QAAAC,KAAA,OAAAP,KAAA,CAAAQ,gBAAA;QAAAE,KAAA;MAAA,GACA;QAAAJ,KAAA;QAAAC,KAAA,OAAAP,KAAA,CAAAgB,eAAA;QAAAN,KAAA;MAAA,GACA;QAAAJ,KAAA;QAAAC,KAAA,OAAAP,KAAA,CAAAiB,eAAA;QAAAP,KAAA;MAAA,EACA;IACA;IACAQ,eAAA;MACA,UAAAlB,KAAA;MACA,YAAAA,KAAA,CAAAkB,cAAA,GAAAC,UAAA,MAAAnB,KAAA,CAAAkB,cAAA,EAAAE,OAAA;IACA;IACAC,OAAA;MACA,UAAArB,KAAA;MACA,YAAAA,KAAA,CAAAqB,MAAA,GAAAF,UAAA,MAAAnB,KAAA,CAAAqB,MAAA,EAAAD,OAAA;IACA;IACAE,cAAA;MACA,UAAAtB,KAAA,UAAAA,KAAA,CAAAuB,YAAA;MACA,MAAAC,QAAA;QAAAC,QAAA;QAAAC,EAAA;QAAAC,MAAA;QAAAC,KAAA;QAA