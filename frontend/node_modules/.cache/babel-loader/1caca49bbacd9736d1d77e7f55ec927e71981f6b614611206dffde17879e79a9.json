{"ast":null,"code":"import \"core-js/modules/es.array.includes.js\";\nimport \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport orderApi from '../api/productionOrders';\nexport default {\n  name: 'QualityCheck',\n  data() {\n    return {\n      serials: [],\n      loading: false,\n      filterStatus: 'NG',\n      filterKeyword: ''\n    };\n  },\n  computed: {\n    filteredSerials() {\n      return this.serials.filter(s => {\n        if (this.filterKeyword && !s.serialCode.toLowerCase().includes(this.filterKeyword.toLowerCase())) return false;\n        return true;\n      });\n    },\n    ngCount() {\n      return this.serials.filter(s => s.status === 'NG').length;\n    },\n    holdCount() {\n      return this.serials.filter(s => s.status === 'HOLD').length;\n    },\n    reworkCount() {\n      return this.serials.filter(s => s.status === 'REWORK').length;\n    }\n  },\n  methods: {\n    async loadSerials() {\n      this.loading = true;\n      try {\n        // Load from all orders and flatten serials with pending status\n        const statusesToCheck = this.filterStatus ? [this.filterStatus] : ['NG', 'HOLD', 'REWORK'];\n        const ordersRes = await orderApi.getAll({\n          status: 'IN_PROGRESS'\n        });\n        const orders = ordersRes.data;\n        let allSerials = [];\n        for (const o of orders) {\n          try {\n            const sRes = await orderApi.getSerials(o.id);\n            const filtered = sRes.data.filter(s => statusesToCheck.includes(s.status));\n            filtered.forEach(s => {\n              s.orderCode = o.orderCode;\n              s.productName = o.productName;\n            });\n            allSerials = allSerials.concat(filtered);\n          } catch (e) {/* skip */}\n        }\n        this.serials = allSerials;\n      } finally {\n        this.loading = false;\n      }\n    },\n    filterData() {/* reactive via computed */},\n    statusBadge(s) {\n      const m = {\n        NG: 'badge-ng',\n        HOLD: 'badge-hold',\n        REWORK: 'badge-rework',\n        SCRAP: 'badge-scrap'\n      };\n      return m[s] || '';\n    },\n    viewTrace(serialCode) {\n      this.$router.push({\n        name: 'Traceability',\n        query: {\n          serial: serialCode\n        }\n      });\n    }\n  },\n  mounted() {\n    this.loadSerials();\n  }\n};","map":{"version":3,"names":["orderApi","name","data","serials","loading","filterStatus","filterKeyword","computed","filteredSerials","filter","s","serialCode","toLowerCase","includes","ngCount","status","length","holdCount","reworkCount","methods","loadSerials","statusesToCheck","ordersRes","getAll","orders","allSerials","o","sRes","getSerials","id","filtered","forEach","orderCode","productName","concat","e","filterData","statusBadge","m","NG","HOLD","REWORK","SCRAP","viewTrace","$router","push","query","serial","mounted"],"sources":["src/views/QualityCheck.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"row mb-4\">\r\n      <div class=\"col-md-4\">\r\n        <div class=\"card card-mes\" style=\"border-top: 4px solid #C62828;\">\r\n          <div class=\"card-body text-center\">\r\n            <h3 class=\"text-danger\">{{ ngCount }}</h3>\r\n            <p class=\"mb-0\">Serial NG cần xử lý</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"col-md-4\">\r\n        <div class=\"card card-mes\" style=\"border-top: 4px solid #F9A825;\">\r\n          <div class=\"card-body text-center\">\r\n            <h3 style=\"color:#F9A825\">{{ holdCount }}</h3>\r\n            <p class=\"mb-0\">Serial HOLD đang chờ</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"col-md-4\">\r\n        <div class=\"card card-mes\" style=\"border-top: 4px solid #6f42c1;\">\r\n          <div class=\"card-body text-center\">\r\n            <h3 class=\"text-purple\">{{ reworkCount }}</h3>\r\n            <p class=\"mb-0\">Serial cần REWORK</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Filters -->\r\n    <div class=\"card card-mes mb-4\">\r\n      <div class=\"card-body\">\r\n        <div class=\"row\">\r\n          <div class=\"col-md-3\">\r\n            <select v-model=\"filterStatus\" @change=\"loadSerials\" class=\"form-control\">\r\n              <option value=\"\">Tất cả trạng thái</option>\r\n              <option value=\"NG\">NG - Không đạt</option>\r\n              <option value=\"HOLD\">HOLD - Giữ lại</option>\r\n              <option value=\"REWORK\">REWORK - Làm lại</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"col-md-3\">\r\n            <input v-model=\"filterKeyword\" @input=\"filterData\" type=\"text\" class=\"form-control\" placeholder=\"Tìm theo serial code...\">\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Serials Table -->\r\n    <div class=\"card card-mes\">\r\n      <div class=\"card-header bg-white\">\r\n        <strong>Danh sách Serial cần xử lý</strong>\r\n      </div>\r\n      <div class=\"card-body p-0\">\r\n        <table class=\"table table-mes mb-0\">\r\n          <thead>\r\n            <tr>\r\n              <th>Serial Code</th>\r\n              <th>Sản phẩm</th>\r\n              <th>Công đoạn</th>\r\n              <th>Trạng thái</th>\r\n              <th>Lỗi gần nhất</th>\r\n              <th>Thao tác</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr v-if=\"loading\">\r\n              <td colspan=\"6\" class=\"text-center py-4\">\r\n                <div class=\"spinner-border spinner-border-sm text-primary mr-2\"></div>Đang tải...\r\n              </td>\r\n            </tr>\r\n            <tr v-else-if=\"!filteredSerials.length\">\r\n              <td colspan=\"6\" class=\"text-center py-4 text-muted\">\r\n                ✅ Không có serial nào cần xử lý\r\n              </td>\r\n            </tr>\r\n            <tr v-for=\"s in filteredSerials\" :key=\"s.id\">\r\n              <td><code>{{ s.serialCode }}</code></td>\r\n              <td>{{ s.productName }}<br><small class=\"text-muted\">{{ s.orderCode }}</small></td>\r\n              <td>{{ s.currentStepName || '—' }}</td>\r\n              <td>\r\n                <span class=\"badge-status\" :class=\"statusBadge(s.status)\">{{ s.status }}</span>\r\n              </td>\r\n              <td class=\"small text-muted\">{{ s.lastDefect || '—' }}</td>\r\n              <td>\r\n                <button class=\"btn btn-sm btn-outline-info\" @click=\"viewTrace(s.serialCode)\">\r\n                  🔗 Truy xuất\r\n                </button>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport orderApi from '../api/productionOrders'\r\n\r\nexport default {\r\n  name: 'QualityCheck',\r\n  data() {\r\n    return {\r\n      serials: [], loading: false,\r\n      filterStatus: 'NG', filterKeyword: ''\r\n    }\r\n  },\r\n  computed: {\r\n    filteredSerials() {\r\n      return this.serials.filter(s => {\r\n        if (this.filterKeyword && !s.serialCode.toLowerCase().includes(this.filterKeyword.toLowerCase())) return false\r\n        return true\r\n      })\r\n    },\r\n    ngCount()     { return this.serials.filter(s => s.status === 'NG').length },\r\n    holdCount()   { return this.serials.filter(s => s.status === 'HOLD').length },\r\n    reworkCount() { return this.serials.filter(s => s.status === 'REWORK').length }\r\n  },\r\n  methods: {\r\n    async loadSerials() {\r\n      this.loading = true\r\n      try {\r\n        // Load from all orders and flatten serials with pending status\r\n        const statusesToCheck = this.filterStatus ? [this.filterStatus] : ['NG', 'HOLD', 'REWORK']\r\n        const ordersRes = await orderApi.getAll({ status: 'IN_PROGRESS' })\r\n        const orders = ordersRes.data\r\n        let allSerials = []\r\n        for (const o of orders) {\r\n          try {\r\n            const sRes = await orderApi.getSerials(o.id)\r\n            const filtered = sRes.data.filter(s => statusesToCheck.includes(s.status))\r\n            filtered.forEach(s => { s.orderCode = o.orderCode; s.productName = o.productName })\r\n            allSerials = allSerials.concat(filtered)\r\n          } catch (e) { /* skip */ }\r\n        }\r\n        this.serials = allSerials\r\n      } finally { this.loading = false }\r\n    },\r\n    filterData() { /* reactive via computed */ },\r\n    statusBadge(s) {\r\n      const m = { NG: 'badge-ng', HOLD: 'badge-hold', REWORK: 'badge-rework', SCRAP: 'badge-scrap' }\r\n      return m[s] || ''\r\n    },\r\n    viewTrace(serialCode) {\r\n      this.$router.push({ name: 'Traceability', query: { serial: serialCode } })\r\n    }\r\n  },\r\n  mounted() { this.loadSerials() }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.text-purple { color: #6f42c1; }\r\n</style>\r\n"],"mappings":";;;;;AAkGA,OAAAA,QAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MAAAC,OAAA;MACAC,YAAA;MAAAC,aAAA;IACA;EACA;EACAC,QAAA;IACAC,gBAAA;MACA,YAAAL,OAAA,CAAAM,MAAA,CAAAC,CAAA;QACA,SAAAJ,aAAA,KAAAI,CAAA,CAAAC,UAAA,CAAAC,WAAA,GAAAC,QAAA,MAAAP,aAAA,CAAAM,WAAA;QACA;MACA;IACA;IACAE,QAAA;MAAA,YAAAX,OAAA,CAAAM,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAK,MAAA,WAAAC,MAAA;IAAA;IACAC,UAAA;MAAA,YAAAd,OAAA,CAAAM,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAK,MAAA,aAAAC,MAAA;IAAA;IACAE,YAAA;MAAA,YAAAf,OAAA,CAAAM,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAK,MAAA,eAAAC,MAAA;IAAA;EACA;EACAG,OAAA;IACA,MAAAC,YAAA;MACA,KAAAhB,OAAA;MACA;QACA;QACA,MAAAiB,eAAA,QAAAhB,YAAA,SAAAA,YAAA;QACA,MAAAiB,SAAA,SAAAtB,QAAA,CAAAuB,MAAA;UAAAR,MAAA;QAAA;QACA,MAAAS,MAAA,GAAAF,SAAA,CAAApB,IAAA;QACA,IAAAuB,UAAA;QACA,WAAAC,CAAA,IAAAF,MAAA;UACA;YACA,MAAAG,IAAA,SAAA3B,QAAA,CAAA4B,UAAA,CAAAF,CAAA,CAAAG,EAAA;YACA,MAAAC,QAAA,GAAAH,IAAA,CAAAzB,IAAA,CAAAO,MAAA,CAAAC,CAAA,IAAAW,eAAA,CAAAR,QAAA,CAAAH,C