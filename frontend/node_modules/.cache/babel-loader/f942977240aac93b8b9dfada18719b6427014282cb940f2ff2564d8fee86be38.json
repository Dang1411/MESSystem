{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport userApi from '../api/users';\n/* global $ */\n\nexport default {\n  name: 'Users',\n  data() {\n    return {\n      users: [],\n      roles: [],\n      loading: false,\n      saving: false,\n      keyword: '',\n      editMode: false,\n      form: {\n        employeeCode: '',\n        fullName: '',\n        username: '',\n        password: '',\n        roleId: '',\n        isActive: true\n      },\n      editId: null,\n      formError: ''\n    };\n  },\n  methods: {\n    async loadUsers() {\n      this.loading = true;\n      try {\n        const res = await userApi.getAll(this.keyword);\n        this.users = res.data;\n      } finally {\n        this.loading = false;\n      }\n    },\n    async loadRoles() {\n      const res = await userApi.getRoles();\n      this.roles = res.data;\n    },\n    roleBadge(role) {\n      const map = {\n        SUPERVISOR: 'badge-warning',\n        OPERATOR: 'badge-info',\n        QC: 'badge-success'\n      };\n      return map[role] || 'badge-secondary';\n    },\n    openCreate() {\n      this.editMode = false;\n      this.editId = null;\n      this.formError = '';\n      this.form = {\n        employeeCode: '',\n        fullName: '',\n        username: '',\n        password: '',\n        roleId: '',\n        isActive: true\n      };\n      $('#userModal').modal('show');\n    },\n    openEdit(u) {\n      this.editMode = true;\n      this.editId = u.id;\n      this.formError = '';\n      const role = this.roles.find(r => r.name === u.roleName);\n      this.form = {\n        employeeCode: u.employeeCode,\n        fullName: u.fullName,\n        username: u.username,\n        password: '',\n        roleId: role ? role.id : '',\n        isActive: u.isActive\n      };\n      $('#userModal').modal('show');\n    },\n    async saveUser() {\n      this.saving = true;\n      this.formError = '';\n      try {\n        const payload = {\n          ...this.form\n        };\n        if (this.editMode && !payload.password) delete payload.password;\n        if (this.editMode) {\n          await userApi.update(this.editId, payload);\n        } else {\n          await userApi.create(payload);\n        }\n        $('#userModal').modal('hide');\n        this.loadUsers();\n      } catch (e) {\n        this.formError = e.response?.data?.message || 'Lỗi khi lưu người dùng';\n      } finally {\n        this.saving = false;\n      }\n    },\n    async confirmDelete(u) {\n      if (!confirm(`Xóa người dùng \"${u.fullName}\"?`)) return;\n      try {\n        await userApi.delete(u.id);\n        this.loadUsers();\n      } catch (e) {\n        alert(e.response?.data?.message || 'Không thể xóa người dùng');\n      }\n    }\n  },\n  mounted() {\n    this.loadUsers();\n    this.loadRoles();\n  }\n};","map":{"version":3,"names":["userApi","name","data","users","roles","loading","saving","keyword","editMode","form","employeeCode","fullName","username","password","roleId","isActive","editId","formError","methods","loadUsers","res","getAll","loadRoles","getRoles","roleBadge","role","map","SUPERVISOR","OPERATOR","QC","openCreate","$","modal","openEdit","u","id","find","r","roleName","saveUser","payload","update","create","e","response","message","confirmDelete","confirm","delete","alert","mounted"],"sources":["src/views/Users.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"d-flex justify-content-between align-items-center mb-4\">\r\n      <div class=\"d-flex gap-2\">\r\n        <input v-model=\"keyword\" @input=\"loadUsers\" type=\"text\" class=\"form-control\" placeholder=\"Tìm theo tên, username...\" style=\"width:280px\">\r\n      </div>\r\n      <button class=\"btn btn-primary\" @click=\"openCreate\">➕ Thêm người dùng</button>\r\n    </div>\r\n\r\n    <div class=\"card card-mes\">\r\n      <div class=\"card-body p-0\">\r\n        <table class=\"table table-mes mb-0\">\r\n          <thead>\r\n            <tr>\r\n              <th>Mã NV</th>\r\n              <th>Họ tên</th>\r\n              <th>Username</th>\r\n              <th>Vai trò</th>\r\n              <th>Trạng thái</th>\r\n              <th>Thao tác</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr v-if=\"loading\">\r\n              <td colspan=\"6\" class=\"text-center py-4\">\r\n                <div class=\"spinner-border spinner-border-sm text-primary mr-2\"></div> Đang tải...\r\n              </td>\r\n            </tr>\r\n            <tr v-else-if=\"!users.length\">\r\n              <td colspan=\"6\" class=\"text-center py-4 text-muted\">Không có dữ liệu</td>\r\n            </tr>\r\n            <tr v-for=\"u in users\" :key=\"u.id\">\r\n              <td><code>{{ u.employeeCode }}</code></td>\r\n              <td>{{ u.fullName }}</td>\r\n              <td>{{ u.username }}</td>\r\n              <td>\r\n                <span class=\"badge\" :class=\"roleBadge(u.roleName)\">{{ u.roleName }}</span>\r\n              </td>\r\n              <td>\r\n                <span class=\"badge-status\" :class=\"u.isActive ? 'badge-active' : 'badge-inactive'\">\r\n                  {{ u.isActive ? 'Hoạt động' : 'Tắt' }}\r\n                </span>\r\n              </td>\r\n              <td>\r\n                <button class=\"btn btn-sm btn-outline-primary mr-1\" @click=\"openEdit(u)\">✏ Sửa</button>\r\n                <button class=\"btn btn-sm btn-outline-danger\" @click=\"confirmDelete(u)\">🗑 Xóa</button>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Modal Create/Edit -->\r\n    <div class=\"modal fade\" id=\"userModal\" tabindex=\"-1\">\r\n      <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n          <div class=\"modal-header\">\r\n            <h5 class=\"modal-title\">{{ editMode ? 'Sửa người dùng' : 'Thêm người dùng' }}</h5>\r\n            <button type=\"button\" class=\"close\" data-dismiss=\"modal\"><span>&times;</span></button>\r\n          </div>\r\n          <form @submit.prevent=\"saveUser\">\r\n            <div class=\"modal-body\">\r\n              <div class=\"alert alert-danger\" v-if=\"formError\">{{ formError }}</div>\r\n              <div class=\"form-group\">\r\n                <label>Mã nhân viên <span class=\"text-danger\">*</span></label>\r\n                <input v-model=\"form.employeeCode\" class=\"form-control\" required :disabled=\"editMode\">\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Họ tên <span class=\"text-danger\">*</span></label>\r\n                <input v-model=\"form.fullName\" class=\"form-control\" required>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Username <span class=\"text-danger\">*</span></label>\r\n                <input v-model=\"form.username\" class=\"form-control\" required :disabled=\"editMode\">\r\n              </div>\r\n              <div class=\"form-group\" v-if=\"!editMode\">\r\n                <label>Mật khẩu <span class=\"text-danger\">*</span></label>\r\n                <input v-model=\"form.password\" type=\"password\" class=\"form-control\" required>\r\n              </div>\r\n              <div class=\"form-group\" v-if=\"editMode\">\r\n                <label>Mật khẩu mới (để trống nếu không đổi)</label>\r\n                <input v-model=\"form.password\" type=\"password\" class=\"form-control\">\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Vai trò <span class=\"text-danger\">*</span></label>\r\n                <select v-model=\"form.roleId\" class=\"form-control\" required>\r\n                  <option value=\"\">-- Chọn vai trò --</option>\r\n                  <option v-for=\"r in roles\" :key=\"r.id\" :value=\"r.id\">{{ r.name }}</option>\r\n                </select>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <div class=\"custom-control custom-switch\">\r\n                  <input type=\"checkbox\" class=\"custom-control-input\" id=\"activeSwitch\" v-model=\"form.isActive\">\r\n                  <label class=\"custom-control-label\" for=\"activeSwitch\">Hoạt động</label>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"modal-footer\">\r\n              <button type=\"button\" class=\"btn btn-secondary\" data-dismiss=\"modal\">Hủy</button>\r\n              <button type=\"submit\" class=\"btn btn-primary\" :disabled=\"saving\">\r\n                {{ saving ? 'Đang lưu...' : 'Lưu' }}\r\n              </button>\r\n            </div>\r\n          </form>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport userApi from '../api/users'\r\n/* global $ */\r\n\r\nexport default {\r\n  name: 'Users',\r\n  data() {\r\n    return {\r\n      users: [], roles: [],\r\n      loading: false, saving: false,\r\n      keyword: '', editMode: false,\r\n      form: { employeeCode: '', fullName: '', username: '', password: '', roleId: '', isActive: true },\r\n      editId: null,\r\n      formError: ''\r\n    }\r\n  },\r\n  methods: {\r\n    async loadUsers() {\r\n      this.loading = true\r\n      try {\r\n        const res = await userApi.getAll(this.keyword)\r\n        this.users = res.data\r\n      } finally { this.loading = false }\r\n    },\r\n    async loadRoles() {\r\n      const res = await userApi.getRoles()\r\n      this.roles = res.data\r\n    },\r\n    roleBadge(role) {\r\n      const map = { SUPERVISOR: 'badge-warning', OPERATOR: 'badge-info', QC: 'badge-success' }\r\n      return map[role] || 'badge-secondary'\r\n    },\r\n    openCreate() {\r\n      this.editMode = false\r\n      this.editId = null\r\n      this.formError = ''\r\n      this.form = { employeeCode: '', fullName: '', username: '', password: '', roleId: '', isActive: true }\r\n      $('#userModal').modal('show')\r\n    },\r\n    openEdit(u) {\r\n      this.editMode = true\r\n      this.editId = u.id\r\n      this.formError = ''\r\n      const role = this.roles.find(r => r.name === u.roleName)\r\n      this.form = {\r\n        employeeCode: u.employeeCode,\r\n        fullName: u.fullName,\r\n        username: u.username,\r\n        password: '',\r\n        roleId: role ? role.id : '',\r\n        isActive: u.isActive\r\n      }\r\n      $('#userModal').modal('show')\r\n    },\r\n    async saveUser() {\r\n      this.saving = true\r\n      this.formError = ''\r\n      try {\r\n        const payload = { ...this.form }\r\n        if (this.editMode && !payload.password) delete payload.password\r\n        if (this.editMode) {\r\n          await userApi.update(this.editId, payload)\r\n        } else {\r\n          await userApi.create(payload)\r\n        }\r\n        $('#userModal').modal('hide')\r\n        this.loadUsers()\r\n      } catch (e) {\r\n        this.formError = e.response?.data?.message || 'Lỗi khi lưu người dùng'\r\n      } finally { this.saving = false }\r\n    },\r\n    async confirmDelete(u) {\r\n      if (!confirm(`Xóa người dùng \"${u.fullName}\"?`)) return\r\n      try {\r\n        await userApi.delete(u.id)\r\n        this.loadUsers()\r\n      } catch (e) {\r\n        alert(e.response?.data?.message || 'Không thể xóa người dùng')\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadUsers()\r\n    this.loadRoles()\r\n  }\r\n}\r\n</script>\r\n"],"mappings":";;AAgHA,OAAAA,OAAA;AACA;;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,KAAA;MAAAC,KAAA;MACAC,OAAA;MAAAC,MAAA;MACAC,OAAA;MAAAC,QAAA;MACAC,IAAA;QAAAC,YAAA;QAAAC,QAAA;QAAAC,QAAA;QAAAC,QAAA;QAAAC,MAAA;QAAAC,QAAA;MAAA;MACAC,MAAA;MACAC,SAAA;IACA;EACA;EACAC,OAAA;IACA,MAAAC,UAAA;MACA,KAAAd,OAAA;MACA;QACA,MAAAe,GAAA,SAAApB,OAAA,CAAAqB,MAAA,MAAAd,OAAA;QACA,KAAAJ,KAAA,GAAAiB,GAAA,CAAAlB,IAAA;MACA;QAAA,KAAAG,OAAA;MAAA;IACA;IACA,MAAAiB,UAAA;MACA,MAAAF,GAAA,SAAApB,OAAA,CAAAuB,QAA