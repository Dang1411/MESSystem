{"ast":null,"code":"import processStepApi from '../api/processSteps';\n/* global $ */\n\nexport default {\n  name: 'ProcessSteps',\n  data() {\n    return {\n      steps: [],\n      loading: false,\n      saving: false,\n      editMode: false,\n      editId: null,\n      formError: '',\n      form: {\n        stepCode: '',\n        stepName: '',\n        description: '',\n        isActive: true\n      }\n    };\n  },\n  methods: {\n    async loadSteps() {\n      this.loading = true;\n      try {\n        const res = await processStepApi.getAll();\n        this.steps = res.data;\n      } finally {\n        this.loading = false;\n      }\n    },\n    openCreate() {\n      this.editMode = false;\n      this.editId = null;\n      this.formError = '';\n      this.form = {\n        stepCode: '',\n        stepName: '',\n        description: '',\n        isActive: true\n      };\n      $('#stepModal').modal('show');\n    },\n    openEdit(s) {\n      this.editMode = true;\n      this.editId = s.id;\n      this.formError = '';\n      this.form = {\n        stepCode: s.stepCode,\n        stepName: s.stepName,\n        description: s.description || '',\n        isActive: s.isActive\n      };\n      $('#stepModal').modal('show');\n    },\n    async saveStep() {\n      this.saving = true;\n      this.formError = '';\n      try {\n        if (this.editMode) await processStepApi.update(this.editId, this.form);else await processStepApi.create(this.form);\n        $('#stepModal').modal('hide');\n        this.loadSteps();\n      } catch (e) {\n        this.formError = e.response?.data?.message || 'Lỗi khi lưu';\n      } finally {\n        this.saving = false;\n      }\n    },\n    async confirmDelete(s) {\n      if (!confirm(`Xóa công đoạn \"${s.stepName}\"?`)) return;\n      try {\n        await processStepApi.delete(s.id);\n        this.loadSteps();\n      } catch (e) {\n        alert(e.response?.data?.message || 'Không thể xóa công đoạn');\n      }\n    }\n  },\n  mounted() {\n    this.loadSteps();\n  }\n};","map":{"version":3,"names":["processStepApi","name","data","steps","loading","saving","editMode","editId","formError","form","stepCode","stepName","description","isActive","methods","loadSteps","res","getAll","openCreate","$","modal","openEdit","s","id","saveStep","update","create","e","response","message","confirmDelete","confirm","delete","alert","mounted"],"sources":["src/views/ProcessSteps.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"d-flex justify-content-between align-items-center mb-4\">\r\n      <p class=\"text-muted mb-0\">Quản lý các công đoạn trong quy trình sản xuất</p>\r\n      <button class=\"btn btn-primary\" @click=\"openCreate\">➕ Thêm công đoạn</button>\r\n    </div>\r\n\r\n    <div class=\"card card-mes\">\r\n      <div class=\"card-body p-0\">\r\n        <table class=\"table table-mes mb-0\">\r\n          <thead>\r\n            <tr>\r\n              <th>Mã công đoạn</th>\r\n              <th>Tên công đoạn</th>\r\n              <th>Mô tả</th>\r\n              <th>Trạng thái</th>\r\n              <th>Thao tác</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr v-if=\"loading\">\r\n              <td colspan=\"5\" class=\"text-center py-4\">\r\n                <div class=\"spinner-border spinner-border-sm text-primary mr-2\"></div>Đang tải...\r\n              </td>\r\n            </tr>\r\n            <tr v-else-if=\"!steps.length\">\r\n              <td colspan=\"5\" class=\"text-center py-4 text-muted\">Chưa có công đoạn nào</td>\r\n            </tr>\r\n            <tr v-for=\"s in steps\" :key=\"s.id\">\r\n              <td><code>{{ s.stepCode }}</code></td>\r\n              <td><strong>{{ s.stepName }}</strong></td>\r\n              <td class=\"text-muted small\">{{ s.description || '—' }}</td>\r\n              <td>\r\n                <span class=\"badge-status\" :class=\"s.isActive ? 'badge-active' : 'badge-inactive'\">\r\n                  {{ s.isActive ? 'Hoạt động' : 'Tắt' }}\r\n                </span>\r\n              </td>\r\n              <td>\r\n                <button class=\"btn btn-sm btn-outline-primary mr-1\" @click=\"openEdit(s)\">✏ Sửa</button>\r\n                <button class=\"btn btn-sm btn-outline-danger\" @click=\"confirmDelete(s)\">🗑 Xóa</button>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Modal -->\r\n    <div class=\"modal fade\" id=\"stepModal\" tabindex=\"-1\">\r\n      <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n          <div class=\"modal-header\">\r\n            <h5 class=\"modal-title\">{{ editMode ? 'Sửa công đoạn' : 'Thêm công đoạn' }}</h5>\r\n            <button type=\"button\" class=\"close\" data-dismiss=\"modal\"><span>&times;</span></button>\r\n          </div>\r\n          <form @submit.prevent=\"saveStep\">\r\n            <div class=\"modal-body\">\r\n              <div class=\"alert alert-danger\" v-if=\"formError\">{{ formError }}</div>\r\n              <div class=\"form-group\">\r\n                <label>Mã công đoạn <span class=\"text-danger\">*</span></label>\r\n                <input v-model=\"form.stepCode\" class=\"form-control\" required :disabled=\"editMode\">\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Tên công đoạn <span class=\"text-danger\">*</span></label>\r\n                <input v-model=\"form.stepName\" class=\"form-control\" required>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Mô tả</label>\r\n                <textarea v-model=\"form.description\" class=\"form-control\" rows=\"3\"></textarea>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <div class=\"custom-control custom-switch\">\r\n                  <input type=\"checkbox\" class=\"custom-control-input\" id=\"stepActive\" v-model=\"form.isActive\">\r\n                  <label class=\"custom-control-label\" for=\"stepActive\">Hoạt động</label>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"modal-footer\">\r\n              <button type=\"button\" class=\"btn btn-secondary\" data-dismiss=\"modal\">Hủy</button>\r\n              <button type=\"submit\" class=\"btn btn-primary\" :disabled=\"saving\">\r\n                {{ saving ? 'Đang lưu...' : 'Lưu' }}\r\n              </button>\r\n            </div>\r\n          </form>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport processStepApi from '../api/processSteps'\r\n/* global $ */\r\n\r\nexport default {\r\n  name: 'ProcessSteps',\r\n  data() {\r\n    return {\r\n      steps: [], loading: false, saving: false,\r\n      editMode: false, editId: null, formError: '',\r\n      form: { stepCode: '', stepName: '', description: '', isActive: true }\r\n    }\r\n  },\r\n  methods: {\r\n    async loadSteps() {\r\n      this.loading = true\r\n      try {\r\n        const res = await processStepApi.getAll()\r\n        this.steps = res.data\r\n      } finally { this.loading = false }\r\n    },\r\n    openCreate() {\r\n      this.editMode = false; this.editId = null; this.formError = ''\r\n      this.form = { stepCode: '', stepName: '', description: '', isActive: true }\r\n      $('#stepModal').modal('show')\r\n    },\r\n    openEdit(s) {\r\n      this.editMode = true; this.editId = s.id; this.formError = ''\r\n      this.form = { stepCode: s.stepCode, stepName: s.stepName, description: s.description || '', isActive: s.isActive }\r\n      $('#stepModal').modal('show')\r\n    },\r\n    async saveStep() {\r\n      this.saving = true; this.formError = ''\r\n      try {\r\n        if (this.editMode) await processStepApi.update(this.editId, this.form)\r\n        else await processStepApi.create(this.form)\r\n        $('#stepModal').modal('hide')\r\n        this.loadSteps()\r\n      } catch (e) {\r\n        this.formError = e.response?.data?.message || 'Lỗi khi lưu'\r\n      } finally { this.saving = false }\r\n    },\r\n    async confirmDelete(s) {\r\n      if (!confirm(`Xóa công đoạn \"${s.stepName}\"?`)) return\r\n      try {\r\n        await processStepApi.delete(s.id)\r\n        this.loadSteps()\r\n      } catch (e) {\r\n        alert(e.response?.data?.message || 'Không thể xóa công đoạn')\r\n      }\r\n    }\r\n  },\r\n  mounted() { this.loadSteps() }\r\n}\r\n</script>\r\n"],"mappings":"AA2FA,OAAAA,cAAA;AACA;;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,KAAA;MAAAC,OAAA;MAAAC,MAAA;MACAC,QAAA;MAAAC,MAAA;MAAAC,SAAA;MACAC,IAAA;QAAAC,QAAA;QAAAC,QAAA;QAAAC,WAAA;QAAAC,QAAA;MAAA;IACA;EACA;EACAC,OAAA;IACA,MAAAC,UAAA;MACA,KAAAX,OAAA;MACA;QACA,MAAAY,GAAA,SAAAhB,cAAA,CAAAiB,MAAA;QACA,KAAAd,KAAA,GAAAa,GAAA,CAAAd,IAAA;MACA;QAAA,KAAAE,OAAA;MAAA;IACA;IACAc,WAAA;MACA,KAAAZ,QAAA;MAAA,KAAAC,MAAA;MAAA,KAAAC,SAAA;MACA,KAAAC,IAAA;QAAAC,QAAA;QAAAC,QAAA;QAAAC,WAAA;QAAAC,QAAA;MAAA;MACAM,CAAA,eAAAC,KAAA;IACA;IACAC,SAAAC,CAAA;MACA,KAAAhB,QAAA;MAAA,KAAAC,MAAA,GAAAe,CAAA,CAAAC,EAAA;MAAA,KAAAf,SAAA;MACA,KAAAC,IAAA;QAAAC,QAAA,EAAAY,CAAA,CAAAZ,QAAA;QAAAC,QAAA,EAAAW,CAAA,CAAAX,QAAA;QAAAC,WAAA,EAAAU,CAAA,CAAAV,WAAA;QAAAC,QAAA,EAAAS,CAAA,CAAAT;MAAA;MACAM,CAAA,eAAAC,KAAA;IACA;IACA,MAAAI,SAAA;MACA,KAAAnB,MAAA;MAAA,KAAAG,SAAA;MACA;QACA,SAAAF,QAAA,QAAAN,cAAA,CAAAyB,MAAA,MAAAlB,MAAA,OAAAE,IAAA,OACA,MAAAT,cAAA,CAAA0B,MAAA,MAAAjB,IAAA;QACAU,CAAA,eAAAC,KAAA;QACA,KAAAL,SAAA;MACA,SAAAY,CAAA;QACA,KAAAnB,SAAA,GAAAmB,CAAA,CAAAC,QAAA,EAAA1B,IAAA,EAAA2B,OAAA;MACA;QAAA,KAAAxB,MAAA;MAAA;IACA;IACA,MAAAyB,cAAAR,CAAA;MACA,KAAAS,OAAA,mBAAAT,CAAA,CAAAX,QAAA;MACA;QACA,MAAAX,cAAA,CAAAgC,MAAA,CAAAV,CAAA,CAAAC,EAAA;QACA,KAAAR,SAAA;MACA,SAAAY,CAAA;QACAM,KAAA,CAAAN,CAAA,CAAAC,QAAA,EAAA1B,IAAA,EAAA2B,OAAA;MACA;IACA;EACA;EACAK,QAAA;IAAA,KAAAnB,SAAA;EAAA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}