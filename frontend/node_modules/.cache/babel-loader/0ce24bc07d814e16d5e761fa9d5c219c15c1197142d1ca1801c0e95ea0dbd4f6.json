{"ast":null,"code":"export default {\n  name: 'App'\n};","map":{"version":3,"names":["name"],"sources":["src/App.vue"],"sourcesContent":["<template>\r\n  <div id=\"app\">\r\n    <router-view />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'App'\r\n}\r\n</script>\r\n\r\n<style>\r\n* {\r\n  box-sizing: border-box;\r\n}\r\n\r\nbody {\r\n  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\r\n  background-color: #f0f2f5;\r\n  color: #333;\r\n}\r\n\r\n/* Scrollbar tùy chỉnh */\r\n::-webkit-scrollbar { width: 6px; }\r\n::-webkit-scrollbar-track { background: #f1f1f1; }\r\n::-webkit-scrollbar-thumb { background: #888; border-radius: 3px; }\r\n::-webkit-scrollbar-thumb:hover { background: #555; }\r\n\r\n/* Badge trạng thái */\r\n.badge-status {\r\n  font-size: 0.78rem;\r\n  padding: 4px 10px;\r\n  border-radius: 20px;\r\n  font-weight: 600;\r\n  letter-spacing: 0.5px;\r\n}\r\n\r\n.badge-waiting    { background: #6c757d; color: #fff; }\r\n.badge-inprogress { background: #0d6efd; color: #fff; }\r\n.badge-ok         { background: #198754; color: #fff; }\r\n.badge-ng         { background: #dc3545; color: #fff; }\r\n.badge-rework     { background: #fd7e14; color: #fff; }\r\n.badge-scrap      { background: #6f42c1; color: #fff; }\r\n.badge-hold       { background: #ffc107; color: #000; }\r\n.badge-finished   { background: #0dcaf0; color: #000; }\r\n\r\n.badge-created    { background: #6c757d; color: #fff; }\r\n.badge-completed  { background: #198754; color: #fff; }\r\n.badge-cancelled  { background: #dc3545; color: #fff; }\r\n.badge-active     { background: #198754; color: #fff; }\r\n.badge-inactive   { background: #6c757d; color: #fff; }\r\n\r\n/* Card công nghiệp */\r\n.card-mes {\r\n  border: none;\r\n  border-radius: 8px;\r\n  box-shadow: 0 2px 8px rgba(0,0,0,0.08);\r\n  transition: box-shadow 0.2s;\r\n}\r\n.card-mes:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.12); }\r\n\r\n/* Table */\r\n.table-mes thead th {\r\n  background: #1a3a5c;\r\n  color: #fff;\r\n  font-weight: 600;\r\n  border: none;\r\n  font-size: 0.85rem;\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.5px;\r\n}\r\n.table-mes tbody tr:hover { background: #e8f4fd; }\r\n\r\n/* Btn */\r\n.btn-mes { border-radius: 6px; font-weight: 500; }\r\n\r\n/* Toast notification */\r\n.toast-container {\r\n  position: fixed;\r\n  top: 20px;\r\n  right: 20px;\r\n  z-index: 9999;\r\n}\r\n</style>\r\n"],"mappings":"AAOA;EACAA,IAAA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}